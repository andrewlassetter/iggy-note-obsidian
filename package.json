{
  "name": "igggy",
  "version": "0.1.0",
  "description": "Igggy — AI structured meeting notes in your Obsidian vault",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "obsidian",
    "notes",
    "ai",
    "meeting",
    "transcription"
  ],
  "author": "Andrew Lassetter",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7"
  }
}
