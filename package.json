{
  "name": "igggy",
  "version": "0.1.0",
  "description": "Igggy — AI structured meeting notes in your Obsidian vault",
  "main": "main.js",
  "scripts": {
    "build:core": "cd ../igggy-web/packages/core && npm run build",
    "dev": "npm run build:core && node esbuild.config.mjs",
    "build": "npm run build:core && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "notes",
    "ai",
    "meeting",
    "transcription"
  ],
  "author": "Andrew Lassetter",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@igggy/core": "file:../igggy-web/packages/core"
  }
}
